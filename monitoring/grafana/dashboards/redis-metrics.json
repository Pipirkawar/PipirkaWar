      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (backend) (rate(pipirik_redis_op_total{backend=~\"$backend\"}[1m]))",
