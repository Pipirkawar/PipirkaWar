[importlinter]
root_packages =
    pipirik_wars
include_external_packages = True

# -----------------------------------------------------------------------------
# Контракт «слои» (layered architecture).
#
# Правило (одно направление зависимостей; любое нарушение → CI падает):
#
#   bot, admin   ──►  application  ──►  domain
#                          ▲
#                          │
#                  infrastructure (адаптеры портов)
#
# • domain      — чистая модель и порты (интерфейсы); зависит ТОЛЬКО от
#                 stdlib. Никаких aiogram/sqlalchemy/asyncpg/pydantic.
# • application — use-cases, оркестрация; зависит от domain. Не знает
#                 ни про БД, ни про Telegram. Может зависеть от pydantic
#                 (DTO) — но не от инфраструктуры.
# • infrastructure — реализации портов (БД, телега, кэш, шедулер).
#                 Зависит от domain и application (их интерфейсов).
# • bot, admin  — точки входа (composition root + handlers/routes).
#                 Знают про всё, но сами не должны быть импортированы
#                 ни одним другим слоем.
# • shared      — общие контракты (errors, types). Может импортироваться
#                 из любого слоя.
# -----------------------------------------------------------------------------

[importlinter:contract:layers]
name = layered_architecture
type = layers
layers =
    pipirik_wars.bot | pipirik_wars.admin | pipirik_wars.admin_web
    pipirik_wars.infrastructure
    pipirik_wars.application
    pipirik_wars.domain
    pipirik_wars.shared

[importlinter:contract:domain-purity]
name = domain_must_not_import_infrastructure
type = forbidden
source_modules =
    pipirik_wars.domain
forbidden_modules =
    pipirik_wars.infrastructure
    pipirik_wars.bot
    pipirik_wars.admin
    pipirik_wars.admin_web
    aiogram
    sqlalchemy
    asyncpg
    httpx
ignore_imports =

[importlinter:contract:application-purity]
name = application_must_not_import_io_libs
type = forbidden
source_modules =
    pipirik_wars.application
forbidden_modules =
    pipirik_wars.infrastructure
    pipirik_wars.bot
    pipirik_wars.admin
    pipirik_wars.admin_web
    aiogram
    sqlalchemy
    asyncpg
    httpx
ignore_imports =

# -----------------------------------------------------------------------------
# Sprint 3.4-A: однонаправленная зависимость inventory → balance (не наоборот).
#
# Логика: `EnchantmentConfig` (и его подмодели `RegularLevelWeights` /
# `BlessedLevelWeights` / `EnchantmentTier`) живут в `domain.balance.config`
# вместе с другими балансовыми сущностями (PvE / Bosses / PvP / ...). Их
# импортирует picker `domain.inventory.services.pick_enchant_outcome` —
# это нормально (inventory читает балансовые типы).
#
# Обратная зависимость (`domain/balance/` → `domain/inventory/`) была бы
# архитектурным запахом: balance — нижний слой настроек, не должен знать
# про domain-объекты конкретных под-доменов (`Item`, `Scroll`, ...). Этот
# контракт ловит регрессию в будущих спринтах (3.4-B/C/D и далее), если
# кто-то по ошибке потянет `Item` или `EnchantOutcome` в `domain.balance`.
# -----------------------------------------------------------------------------

[importlinter:contract:balance-not-depending-on-inventory]
name = balance_must_not_import_inventory
type = forbidden
source_modules =
    pipirik_wars.domain.balance
forbidden_modules =
    pipirik_wars.domain.inventory
ignore_imports =

# -----------------------------------------------------------------------------
# Sprint 4.5-A: bot and admin_web are isolated entry points.
# -----------------------------------------------------------------------------

[importlinter:contract:bot-not-importing-admin-web]
name = bot_must_not_import_admin_web
type = forbidden
source_modules =
    pipirik_wars.bot
forbidden_modules =
    pipirik_wars.admin_web
ignore_imports =

[importlinter:contract:admin-web-not-importing-bot]
name = admin_web_must_not_import_bot
type = forbidden
source_modules =
    pipirik_wars.admin_web
forbidden_modules =
    pipirik_wars.bot
ignore_imports =
