# Telegram
BOT_TOKEN=

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pipirik_wars

# Cache (in-memory by default; Redis на Фазе 4+)
REDIS_URL=

# Admin: bootstrap первого super_admin-а
# Список tg_id админов через запятую (например: 123456789,987654321).
# При первом старте бота, если таблица `admins` пуста — каждому из этих
# tg_id выдаётся роль super_admin (одноразово). Если таблица не пуста —
# переменная игнорируется. Хранить в Devin Secrets, не в git.
BOOTSTRAP_ADMIN_IDS=

# Admin panel (опционально, Спринт 4.5)
ADMIN_BASE_URL=http://localhost:8000
ADMIN_TG_LOGIN_BOT_USERNAME=
ADMIN_SECRET_KEY=

# Payments (Phase 4)
TON_API_KEY=
USDT_PROCESSOR_API_KEY=

# Logging / metrics
LOG_LEVEL=INFO
METRICS_ENABLED=true

# DAU Gate
MAX_DAU=200
